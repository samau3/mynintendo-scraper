# PostgreSQL connection string (required)
# Local docker-compose default: postgresql://dev:dev@localhost:5432/mynintendo
DATABASE_URL=postgresql://user:password@localhost:5432/mynintendo

# Discord webhook notifications (optional for local dev — scraping works without these)
# Create a webhook at https://discord.com/developers/docs/resources/webhook
WEBHOOK_ID=your_webhook_id
WEBHOOK_TOKEN=your_webhook_token
DISCORD_USER_ID=your_discord_user_id
